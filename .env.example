APP_NAME=EmoSync
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=${APP_URL}
FRONTEND_URL=${FRONTEND_URL}

SANCTUM_STATEFUL_DOMAINS=${SANCTUM_STATEFUL_DOMAINS}
SESSION_DOMAIN=${SESSION_DOMAIN}

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — Supabase PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=${SUPABASE_HOST}
DB_PORT=${SUPABASE_PORT:-6543}
DB_DATABASE=${SUPABASE_DATABASE:-postgres}
DB_USERNAME=${SUPABASE_USER}
DB_PASSWORD=${SUPABASE_PASSWORD}

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Cache
CACHE_DRIVER=redis
CACHE_STORE=redis

# Redis — Upstash
REDIS_CLIENT=predis
REDIS_HOST=${UPSTASH_HOST}
REDIS_PASSWORD=${UPSTASH_PASSWORD}
REDIS_PORT=${UPSTASH_PORT:-6379}

# Queue
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Mail
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS (optional, for S3 storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Supabase Storage (S3-compatible)
SUPABASE_S3_KEY=${SUPABASE_S3_KEY}
SUPABASE_S3_SECRET=${SUPABASE_S3_SECRET}
SUPABASE_S3_REGION=${SUPABASE_S3_REGION:-ap-southeast-1}
SUPABASE_S3_ENDPOINT=${SUPABASE_S3_ENDPOINT}
SUPABASE_S3_URL=${SUPABASE_S3_URL}
SUPABASE_BUCKET=${SUPABASE_BUCKET:-emosync}
